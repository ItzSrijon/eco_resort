<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="650.0" prefWidth="850.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Nazmun.ManageKitchenStaffController">

    <Label layoutX="270.0" layoutY="20.0" text="Kitchen Staff Management">
        <font><javafx.scene.text.Font name="System Bold" size="22.0" /></font>
    </Label>

    <TableView fx:id="kitchenStaffTableView" layoutX="30.0" layoutY="80.0" prefHeight="290.0" prefWidth="790.0">
        <columns>
            <TableColumn fx:id="staffNameTC" prefWidth="200.0" text="Name" />
            <TableColumn fx:id="roleTC" prefWidth="180.0" text="Role" />
            <TableColumn fx:id="shiftTC" prefWidth="180.0" text="Shift" />
            <TableColumn fx:id="statusTC" prefWidth="180.0" text="Status" />
        </columns>
    </TableView>

    <Label layoutX="30.0" layoutY="390.0" text="Task Description" />
    <TextField fx:id="taskDescriptionTF" layoutX="170.0" layoutY="386.0" prefWidth="220.0" />

    <Label layoutX="410.0" layoutY="390.0" text="Time Slot" />
    <TextField fx:id="timeSlotTF" layoutX="490.0" layoutY="386.0" prefWidth="140.0" />

    <Button layoutX="30.0" layoutY="430.0" onAction="#assignDailyTaskButtonOA" text="Assign Task" />

    <Label fx:id="shiftConflictLabel" layoutX="30.0" layoutY="470.0" textFill="RED" />

    <Button layoutX="30.0" layoutY="590.0" onAction="#backButtonOA" text="Back" />

</AnchorPane>