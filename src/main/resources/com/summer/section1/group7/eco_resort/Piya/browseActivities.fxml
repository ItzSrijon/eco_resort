<?import javafx.scene.control.TableView?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="messageLabel" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Piya.controller.BrowseActivitiesController">
   <children>
      <Label layoutX="63.0" layoutY="30.0" />
      <Label alignment="CENTER" contentDisplay="CENTER" layoutX="187.0" layoutY="22.0" prefHeight="17.0" prefWidth="174.0" text="Browse Activities !!!">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <Label layoutX="91.0" layoutY="291.0" prefHeight="68.0" prefWidth="268.0" />
      <TableView fx:id="activityTableView" layoutX="89.0" layoutY="68.0" prefHeight="200.0" prefWidth="343.0">
        <columns>
          <TableColumn fx:id="activityNameTC" prefWidth="92.5" text="Activity Name" />
          <TableColumn fx:id="categoryTC" prefWidth="95.0" text="Category" />
            <TableColumn fx:id="scheduleTC" prefWidth="68.5" text="Schedule" />
            <TableColumn fx:id="feeTC" prefWidth="86.0" text="Fee" />
        </columns>
      </TableView>
      <Button layoutX="472.0" layoutY="282.0" mnemonicParsing="false" onAction="#backButtonOA" text="Back">
         <effect>
            <DropShadow />
         </effect>
      </Button>
      <Button layoutX="453.0" layoutY="243.0" mnemonicParsing="false" onAction="#joinActivityButtonOA" text="join Activity">
         <effect>
            <DropShadow />
         </effect>
      </Button>
   </children>
</AnchorPane>
