<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="400.0" prefWidth="689.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Piya.controller.ViewIncidentsController">
   <children>
      <Label layoutX="45.0" layoutY="41.0" text="Incident List" />
      <TableView fx:id="incidentTableView" layoutX="22.0" layoutY="74.0" prefHeight="200.0" prefWidth="550.0">
        <columns>
          <TableColumn fx:id="incidentIdTC" prefWidth="75.0" text="Incident ID" />
          <TableColumn fx:id="incidentTypeTC" prefWidth="86.5" text="Incident Type" />
            <TableColumn fx:id="locationTC" prefWidth="87.0" text="Location" />
            <TableColumn fx:id="descriptionTC" prefWidth="98.5" text="Description" />
            <TableColumn fx:id="dateTC" prefWidth="95.5" text="Date" />
            <TableColumn fx:id="dateTC1" prefWidth="106.5" text="Reported By" />
        </columns>
      </TableView>
      <Button layoutX="588.0" layoutY="141.0" mnemonicParsing="false" onAction="#viewDetailsButtonOA" prefHeight="59.0" prefWidth="73.0" text="View" />
      <Button layoutX="590.0" layoutY="215.0" mnemonicParsing="false" onAction="#deleteButtonOA" prefHeight="67.0" prefWidth="73.0" text="Delete" />
      <Label layoutX="272.0" layoutY="14.0" text="View Incidents">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <Label fx:id="messageLabel" layoutX="32.0" layoutY="305.0" prefHeight="59.0" prefWidth="253.0" />
      <Button layoutX="588.0" layoutY="305.0" mnemonicParsing="false" onAction="#backButtonOA" prefHeight="67.0" prefWidth="73.0" text="Back" />
   </children>
</AnchorPane>
