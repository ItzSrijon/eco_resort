<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="650.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Nazmun.ManageReservationsController">

    <Label layoutX="330.0" layoutY="20.0" text="Manage Reservations">
        <font><javafx.scene.text.Font name="System Bold" size="24.0" /></font>
    </Label>

    <Label layoutX="30.0" layoutY="80.0" text="Guest Name" />
    <TextField fx:id="guestNameTF" layoutX="130.0" layoutY="76.0" prefWidth="160.0" />

    <Label layoutX="320.0" layoutY="80.0" text="Contact Number" />
    <TextField fx:id="contactNumberTF" layoutX="440.0" layoutY="76.0" prefWidth="160.0" />

    <Label layoutX="30.0" layoutY="120.0" text="Room Type" />
    <ComboBox fx:id="roomTypeCB" layoutX="130.0" layoutY="116.0" prefWidth="160.0" />

    <Label layoutX="320.0" layoutY="120.0" text="Check-In Date" />
    <DatePicker fx:id="checkInDP" layoutX="440.0" layoutY="116.0" prefWidth="160.0" />

    <Label layoutX="30.0" layoutY="160.0" text="Check-Out Date" />
    <DatePicker fx:id="checkOutDP" layoutX="130.0" layoutY="156.0" prefWidth="160.0" />

    <Button layoutX="30.0" layoutY="200.0" onAction="#checkAvailabilityButtonOA" text="Check Availability" />
    <Button layoutX="190.0" layoutY="200.0" onAction="#saveReservationButtonOA" text="Save Reservation" />
    <Button layoutX="350.0" layoutY="200.0" onAction="#checkInButtonOA" text="Process Check-In" />
    <Button layoutX="510.0" layoutY="200.0" onAction="#checkOutButtonOA" text="Process Check-Out" />

    <Label fx:id="reservationStatusLabel" layoutX="30.0" layoutY="235.0" />

    <TableView fx:id="reservationsTableView" layoutX="30.0" layoutY="270.0" prefHeight="320.0" prefWidth="840.0">
        <columns>
            <TableColumn fx:id="guestNameTC" prefWidth="140.0" text="Guest Name" />
            <TableColumn fx:id="contactTC" prefWidth="110.0" text="Contact" />
            <TableColumn fx:id="roomTypeTC" prefWidth="100.0" text="Room Type" />
            <TableColumn fx:id="checkInTC" prefWidth="120.0" text="Check-In" />
            <TableColumn fx:id="checkOutTC" prefWidth="120.0" text="Check-Out" />
            <TableColumn fx:id="statusTC" prefWidth="100.0" text="Status" />
            <TableColumn fx:id="totalBillTC" prefWidth="100.0" text="Total Bill" />
        </columns>
    </TableView>

    <Button layoutX="30.0" layoutY="605.0" onAction="#backButtonOA" text="Back" />

</AnchorPane>
