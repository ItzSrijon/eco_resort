<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Piya.controller.CheckInRecordsController">
   <children>
      <Label layoutX="233.0" layoutY="14.0" text="Check-In Records">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <TableView fx:id="checkInTableView" layoutX="107.0" layoutY="78.0" prefHeight="200.0" prefWidth="438.0">
        <columns>
          <TableColumn fx:id="recordIdTC" prefWidth="75.0" text="Record ID" />
          <TableColumn fx:id="guestNameTC" prefWidth="90.0" text="Guest Name" />
            <TableColumn fx:id="roomNumberTC" prefWidth="109.5" text="Room Number" />
            <TableColumn fx:id="checkInDateTC" prefWidth="91.0" text="Check-In Date" />
            <TableColumn fx:id="timeTC" prefWidth="71.5" text="Time" />
        </columns>
      </TableView>
      <Button layoutX="326.0" layoutY="295.0" mnemonicParsing="false" onAction="#refreshButtonOA" prefHeight="25.0" prefWidth="114.0" text="Refresh" />
      <Label layoutX="118.0" layoutY="46.0" text="Guest Check-In List !!!" />
      <Label fx:id="mssageLabel" layoutX="51.0" layoutY="310.0" prefHeight="74.0" prefWidth="214.0" />
      <Button layoutX="319.0" layoutY="335.0" mnemonicParsing="false" onAction="#backButtonOA" prefHeight="25.0" prefWidth="134.0" text="Back" />
   </children>
</AnchorPane>
