<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="650.0" prefWidth="850.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Nazmun.ManageFoodBeverageController">

    <Label layoutX="260.0" layoutY="20.0" text="Food and Beverage Management">
        <font><javafx.scene.text.Font name="System Bold" size="22.0" /></font>
    </Label>

    <TableView fx:id="menuTableView" layoutX="30.0" layoutY="80.0" prefHeight="280.0" prefWidth="790.0">
        <columns>
            <TableColumn fx:id="itemNameTC" prefWidth="220.0" text="Item Name" />
            <TableColumn fx:id="categoryTC" prefWidth="180.0" text="Category" />
            <TableColumn fx:id="priceTC" prefWidth="150.0" text="Price" />
            <TableColumn fx:id="stockStatusTC" prefWidth="180.0" text="Stock Status" />
        </columns>
    </TableView>

    <Label layoutX="30.0" layoutY="380.0" text="New Price" />
    <TextField fx:id="newPriceTF" layoutX="110.0" layoutY="376.0" prefWidth="100.0" />

    <Button layoutX="230.0" layoutY="375.0" onAction="#updatePriceButtonOA" text="Update Price" />
    <Button layoutX="360.0" layoutY="375.0" onAction="#publishMenuButtonOA" text="Publish Menu" />
    <Button layoutX="500.0" layoutY="375.0" onAction="#sendBackToChefButtonOA" text="Send Back to Chef" />

    <Label layoutX="30.0" layoutY="420.0" text="Revision Comments" />
    <TextArea fx:id="revisionCommentsTF" layoutX="30.0" layoutY="445.0" prefHeight="60.0" prefWidth="500.0" />

    <Label layoutX="30.0" layoutY="530.0" text="Today's F&amp;B Revenue" />
    <Label fx:id="dailyRevenueLabel" layoutX="180.0" layoutY="530.0" text="-" />

    <Label layoutX="330.0" layoutY="530.0" text="Today's F&amp;B Expense" />
    <Label fx:id="dailyExpenseLabel" layoutX="480.0" layoutY="530.0" text="-" />

    <Label fx:id="stockWarningLabel" layoutX="30.0" layoutY="560.0" textFill="RED" />

    <Button layoutX="30.0" layoutY="600.0" onAction="#backButtonOA" text="Back" />

</AnchorPane>
