<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="650.0" prefWidth="850.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Nazmun.ManageRoomManagementController">

    <Label layoutX="300.0" layoutY="20.0" text="Room Management">
        <font><javafx.scene.text.Font name="System Bold" size="24.0" /></font>
    </Label>

    <TableView fx:id="roomsTableView" layoutX="30.0" layoutY="80.0" prefHeight="330.0" prefWidth="790.0">
        <columns>
            <TableColumn fx:id="roomNoTC" prefWidth="120.0" text="Room No" />
            <TableColumn fx:id="roomTypeTC" prefWidth="150.0" text="Room Type" />
            <TableColumn fx:id="currentRateTC" prefWidth="150.0" text="Current Rate" />
            <TableColumn fx:id="occupancyStatusTC" prefWidth="150.0" text="Occupancy Status" />
        </columns>
    </TableView>

    <Label layoutX="30.0" layoutY="430.0" text="New Rate" />
    <TextField fx:id="newRateTF" layoutX="110.0" layoutY="426.0" prefWidth="120.0" />

    <Label layoutX="270.0" layoutY="430.0" text="New Status" />
    <ComboBox fx:id="newStatusCB" layoutX="360.0" layoutY="426.0" prefWidth="150.0" />

    <Button layoutX="540.0" layoutY="425.0" onAction="#updateRoomButtonOA" text="Update Room" />

    <Label fx:id="pricingErrorLabel" layoutX="30.0" layoutY="465.0" textFill="RED" />

    <Label layoutX="30.0" layoutY="500.0" text="Occupied Rooms" />
    <Label fx:id="occupiedCountLabel" layoutX="150.0" layoutY="500.0" text="0" />

    <Label layoutX="280.0" layoutY="500.0" text="Vacant Rooms" />
    <Label fx:id="vacantCountLabel" layoutX="390.0" layoutY="500.0" text="0" />

    <Label layoutX="500.0" layoutY="500.0" text="Occupancy Rate" />
    <Label fx:id="occupancyRateLabel" layoutX="620.0" layoutY="500.0" text="0%" />

    <Button layoutX="30.0" layoutY="580.0" onAction="#backButtonOA" text="Back" />

</AnchorPane>