<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="650.0" prefWidth="850.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Nazmun.ManageEcoMetricsController">

    <Label layoutX="270.0" layoutY="20.0" text="Eco Sustainability Metrics">
        <font><javafx.scene.text.Font name="System Bold" size="22.0" /></font>
    </Label>

    <TableView fx:id="ecoMetricsTableView" layoutX="30.0" layoutY="80.0" prefHeight="290.0" prefWidth="790.0">
        <columns>
            <TableColumn fx:id="metricNameTC" prefWidth="180.0" text="Metric" />
            <TableColumn fx:id="currentUsageTC" prefWidth="190.0" text="Current Usage" />
            <TableColumn fx:id="targetTC" prefWidth="190.0" text="Target" />
            <TableColumn fx:id="comparisonTC" prefWidth="220.0" text="Over / Under Target" />
        </columns>
    </TableView>

    <Label fx:id="ecoAlertLabel" layoutX="30.0" layoutY="390.0" textFill="RED" />

    <Label layoutX="30.0" layoutY="430.0" text="Corrective Action Notes" />
    <TextArea fx:id="correctiveNotesTF" layoutX="30.0" layoutY="455.0" prefHeight="70.0" prefWidth="600.0" />

    <Button layoutX="30.0" layoutY="545.0" onAction="#saveEcoReportButtonOA" text="Save and Share Eco Report" />

    <Label fx:id="ecoStatusLabel" layoutX="260.0" layoutY="550.0" />

    <Button layoutX="30.0" layoutY="600.0" onAction="#backButtonOA" text="Back" />

</AnchorPane>
