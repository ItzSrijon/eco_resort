<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="600.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.summer.section1.group7.eco_resort.Nazmun.Controller.ChefOverseeDailyPreparationController">

    <Label layoutX="270.0" layoutY="20.0" text="Daily Food Preparation">
        <font><javafx.scene.text.Font name="System Bold" size="24.0" /></font>
    </Label>

    <TableView fx:id="todaysOrdersTableView" layoutX="30.0" layoutY="80.0" prefHeight="290.0" prefWidth="790.0">
        <columns>
            <TableColumn fx:id="dishNameTC" prefWidth="220.0" text="Dish Name" />
            <TableColumn fx:id="quantityTC" prefWidth="150.0" text="Quantity" />
            <TableColumn fx:id="notesTC" prefWidth="400.0" text="Special Notes" />
        </columns>
    </TableView>

    <Label layoutX="30.0" layoutY="390.0" text="Assign Station" />
    <ComboBox fx:id="stationCB" layoutX="150.0" layoutY="386.0" prefWidth="180.0" />

    <Label layoutX="360.0" layoutY="390.0" text="Assign Staff" />
    <ComboBox fx:id="assignedStaffCB" layoutX="470.0" layoutY="386.0" prefWidth="180.0" />

    <Button layoutX="30.0" layoutY="430.0" onAction="#assignTaskButtonOA" text="Assign Preparation Task" />

    <Label fx:id="unavailabilityIssueLabel" layoutX="30.0" layoutY="470.0" textFill="RED" />
    <Label fx:id="taskStatusLabel" layoutX="30.0" layoutY="500.0" />

    <Button layoutX="30.0" layoutY="590.0" onAction="#backButtonOA" text="Back" />

</AnchorPane>