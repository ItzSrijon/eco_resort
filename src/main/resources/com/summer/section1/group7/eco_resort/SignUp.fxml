<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500.0" prefWidth="400.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.summer.section1.group7.eco_resort.SignUpController">
    <children>
        <VBox alignment="CENTER" spacing="15.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label text="Create Account" style="-fx-font-size: 24px; -fx-font-weight: bold;" />

                <ComboBox fx:id="userTypeComboBox" prefWidth="220.0" promptText="Select User Type" />

                <TextField fx:id="usernameField" prefWidth="220.0" promptText="Username" />

                <PasswordField fx:id="passwordField" prefWidth="220.0" promptText="Password" />

                <PasswordField fx:id="confirmPasswordField" prefWidth="220.0" promptText="Confirm Password" />

                <Button fx:id="signupButton" onAction="#handleSignup" prefWidth="180.0" text="Sign Up" />

                <Label fx:id="messageLabel" textFill="RED" />

                <Button fx:id="goToLoginButton" onAction="#handleGoToLogin" style="-fx-background-color: transparent; -fx-text-fill: #2255cc; -fx-underline: true;" text="Back to Login" />
            </children>
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
        </VBox>
    </children>
</AnchorPane>