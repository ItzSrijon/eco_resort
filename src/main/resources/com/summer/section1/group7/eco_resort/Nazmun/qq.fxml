<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="600.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ManagerDashboardController">

    <Label layoutX="270.0" layoutY="40.0" text="Manager Dashboard">
        <font><javafx.scene.text.Font name="System Bold" size="24.0" /></font>
    </Label>

    <Label layoutX="290.0" layoutY="90.0" text="Welcome to your Dashboard !!!" />

    <Button layoutX="140.0" layoutY="160.0" onAction="#reservationsButtonOA" prefWidth="180.0" text="Reservations" />
    <Button layoutX="420.0" layoutY="160.0" onAction="#roomManagementButtonOA" prefWidth="180.0" text="Room Management" />

    <Button layoutX="140.0" layoutY="220.0" onAction="#foodBeverageButtonOA" prefWidth="180.0" text="Food and Beverage" />
    <Button layoutX="420.0" layoutY="220.0" onAction="#staffManagementButtonOA" prefWidth="180.0" text="Staff Management" />

    <Button layoutX="140.0" layoutY="280.0" onAction="#budgetFinanceButtonOA" prefWidth="180.0" text="Budget and Finance" />
    <Button layoutX="420.0" layoutY="280.0" onAction="#safetyInspectionButtonOA" prefWidth="180.0" text="Safety Inspection" />

    <Button layoutX="280.0" layoutY="340.0" onAction="#ecoMetricsButtonOA" prefWidth="180.0" text="Eco Metrics" />

    <Button layoutX="280.0" layoutY="420.0" onAction="#logoutButtonOA" prefWidth="180.0" text="Logout" />

    <Label fx:id="loginErrorLabel" layoutX="270.0" layoutY="470.0" textFill="RED" />

</AnchorPane>
