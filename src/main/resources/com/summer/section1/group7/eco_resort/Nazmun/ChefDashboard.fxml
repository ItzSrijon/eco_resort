<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="600.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.summer.section1.group7.eco_resort.Nazmun.Controller.ChefDashboardController">

    <Label layoutX="290.0" layoutY="40.0" text="Kitchen Dashboard">
        <font><javafx.scene.text.Font name="System Bold" size="24.0" /></font>
    </Label>

    <Label layoutX="290.0" layoutY="90.0" text="Welcome to your Dashboard !!!" />

    <Button layoutX="140.0" layoutY="160.0" onAction="#menuManagementButtonOA" prefWidth="180.0" text="Menu Management" />
    <Button layoutX="420.0" layoutY="160.0" onAction="#dailyPreparationButtonOA" prefWidth="180.0" text="Daily Preparation" />

    <Button layoutX="140.0" layoutY="220.0" onAction="#kitchenStaffButtonOA" prefWidth="180.0" text="Kitchen Staff" />
    <Button layoutX="420.0" layoutY="220.0" onAction="#kitchenInventoryButtonOA" prefWidth="180.0" text="Kitchen Inventory" />

    <Button layoutX="140.0" layoutY="280.0" onAction="#foodQualityButtonOA" prefWidth="180.0" text="Food Quality Inspection" />
    <Button layoutX="420.0" layoutY="280.0" onAction="#ecoMealPlanningButtonOA" prefWidth="180.0" text="Eco Meal Planning" />

    <Button layoutX="280.0" layoutY="340.0" onAction="#foodWasteLogButtonOA" prefWidth="180.0" text="Food Waste Log" />

    <Button layoutX="280.0" layoutY="420.0" onAction="#logoutButtonOA" prefWidth="180.0" text="Logout" />

    <Label fx:id="loginErrorLabel" layoutX="270.0" layoutY="470.0" textFill="RED" />

</AnchorPane>
