<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="650.0" prefWidth="850.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.summer.section1.group7.eco_resort.Nazmun.Controller.ManageFoodWasteLogController">

    <Label layoutX="320.0" layoutY="20.0" text="Food Waste Log">
        <font><javafx.scene.text.Font name="System Bold" size="24.0" /></font>
    </Label>

    <TableView fx:id="wasteLogTableView" layoutX="30.0" layoutY="80.0" prefHeight="260.0" prefWidth="790.0">
        <columns>
            <TableColumn fx:id="itemNameTC" prefWidth="260.0" text="Item Name" />
            <TableColumn fx:id="quantityTC" prefWidth="260.0" text="Quantity" />
            <TableColumn fx:id="reasonTC" prefWidth="260.0" text="Reason" />
        </columns>
    </TableView>

    <Label layoutX="30.0" layoutY="360.0" text="Wasted Item Name" />
    <TextField fx:id="wastedItemTF" layoutX="170.0" layoutY="356.0" prefWidth="180.0" />

    <Label layoutX="380.0" layoutY="360.0" text="Quantity" />
    <TextField fx:id="wasteQuantityTF" layoutX="450.0" layoutY="356.0" prefWidth="100.0" />

    <Label layoutX="30.0" layoutY="400.0" text="Reason" />
    <ComboBox fx:id="wasteReasonCB" layoutX="170.0" layoutY="396.0" prefWidth="180.0" />

    <Button layoutX="30.0" layoutY="440.0" onAction="#saveWasteEntryButtonOA" text="Save Waste Entry" />

    <Label fx:id="thresholdWarningLabel" layoutX="30.0" layoutY="480.0" textFill="RED" />

    <Button layoutX="30.0" layoutY="590.0" onAction="#backButtonOA" text="Back" />

</AnchorPane>