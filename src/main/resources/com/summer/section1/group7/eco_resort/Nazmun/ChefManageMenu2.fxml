<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="650.0" prefWidth="850.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Nazmun.ManageMenuController">

    <Label layoutX="320.0" layoutY="20.0" text="Menu Management">
        <font><javafx.scene.text.Font name="System Bold" size="24.0" /></font>
    </Label>

    <TableView fx:id="menuItemsTableView" layoutX="30.0" layoutY="80.0" prefHeight="280.0" prefWidth="790.0">
        <columns>
            <TableColumn fx:id="itemNameTC" prefWidth="250.0" text="Item Name" />
            <TableColumn fx:id="categoryTC" prefWidth="220.0" text="Category" />
            <TableColumn fx:id="priceTC" prefWidth="200.0" text="Price" />
        </columns>
    </TableView>

    <Label layoutX="30.0" layoutY="380.0" text="Item Name" />
    <TextField fx:id="itemNameTF" layoutX="130.0" layoutY="376.0" prefWidth="160.0" />

    <Label layoutX="320.0" layoutY="380.0" text="Category" />
    <ComboBox fx:id="categoryCB" layoutX="400.0" layoutY="376.0" prefWidth="160.0" />

    <Label layoutX="30.0" layoutY="420.0" text="Price" />
    <TextField fx:id="priceTF" layoutX="130.0" layoutY="416.0" prefWidth="160.0" />

    <Button layoutX="30.0" layoutY="460.0" onAction="#saveMenuItemButtonOA" text="Save Menu Item" />

    <Label fx:id="ingredientWarningLabel" layoutX="30.0" layoutY="500.0" textFill="RED" />

    <Button layoutX="30.0" layoutY="590.0" onAction="#backButtonOA" text="Back" />

</AnchorPane>
